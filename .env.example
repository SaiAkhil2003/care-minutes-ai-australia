# Required for app startup and Supabase access
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional public base URL used in email links
NEXT_PUBLIC_APP_URL=https://your-app.example.com

# Required only if AI-generated alert summaries are enabled
GEMINI_API_KEY=your-gemini-api-key

# Required for email delivery
RESEND_API_KEY=your-resend-api-key
ALERT_FROM_EMAIL=alerts@your-domain.com

# Optional: defaults to enabled unless explicitly set to false
AUTO_ALERT_ENABLED=true

# Required if Inngest is configured in deployment
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key
